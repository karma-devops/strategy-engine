# =============================================================================
# PULS-R Strategy Engine — Environment Template (PUBLIC, no secrets)
# Copy to `.env` and fill in real values. `.env` is gitignored.
# =============================================================================

# --- Core app ---
STRATEGY_ENGINE_PORT=8792          # Port the uvicorn server binds to
FLASK_SECRET_KEY=                  # Session secret (generate: python -c "import secrets; print(secrets.token_hex(32))")
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# --- Dashboard auth (Basic Auth for UI) ---
DASHBOARD_USERNAME=operator         # UI login user
DASHBOARD_PASSWORD=operator         # UI login password (CHANGE THIS in production)

# --- Agent API key (for programmatic REST access; sent as X-API-Key header) ---
AGENT_API_KEY=                      # Required for /api/v2/* calls. Generate any strong string.

# --- HyperLiquid exchange credentials (ONLY needed for LIVE trading) ---
# Leave blank for Paper/Backtest mode.
HYPER_LIQUID_ETH_PRIVATE_KEY=      # Ethereum private key for HyperLiquid L1 action signing
ACCOUNT_ADDRESS=                    # HyperLiquid account address (0x...)
INSTANCE_SECRET_KEY=               # Per-instance secret for engine auth (optional)

# --- AI assistant (optional; used by assistant.html chat widget) ---
AI_API_URL=https://api.openai.com/v1   # OpenAI-compatible endpoint
AI_API_KEY=                            # LLM API key (optional; leave blank to disable chat)

# --- Database (optional override; defaults to main/data/strategy_engine.db) ---
# DATABASE_URL=sqlite:///./data/strategy_engine.db

# --- Withdrawal config (optional; see withdrawal/calculator.py) ---
# WITHDRAWAL_CYCLE_DAYS=7
# WITHDRAWAL_RATE=0.5
