//@version=6
// Strategy: Eve Engine v1.3 - [UNIFIED]
// Built by Eve for Operator - Swing & Scalp Modes
// NO TIMEFRAME-DEPENDENT CODE - ACCURATE BACKTESTING

strategy('Eve Engine v1.3 - UNIFIED [Swing/Scalp]', 
  overlay = true, 
  initial_capital = 100, 
  default_qty_type = strategy.percent_of_equity, 
  default_qty_value = 100, 
  currency = currency.USDT, 
  commission_type = strategy.commission.percent, 
  commission_value = 0.05, 
  slippage = 5, 
  pyramiding = 1, 
  calc_on_every_tick = true,
  process_orders_on_close = true)

// ══════════════════════════════════════════════════════════════════════════════
//  CONSTANTS & SAFETY GUARDS
// ══════════════════════════════════════════════════════════════════════════════

FLOAT_EPSILON = 0.0001
MIN_ATR_MULT = 0.5
MAX_ATR_MULT = 3.0
MIN_ADAPTIVE_LEN = 6
MAX_ADAPTIVE_LEN = 30
VOLATILITY_FLOOR = 1.0
EQUITY_CURVE_MIN_SAMPLES = 3
MAX_EQUITY_HISTORY = 100

// ══════════════════════════════════════════════════════════════════════════════
//  ENGINE MODE SELECTOR (MANUAL TOGGLE - NO AUTO-DETECT)
// ══════════════════════════════════════════════════════════════════════════════

engineMode = input.string('Swing', 'ENGINE MODE', options = ['Swing', 'Scalp'], group = '⚙️ Configuration', tooltip = 'Swing = 30m-3h trends | Scalp = 5m-15m quick trades')

// Mode-aware defaults
isSwingMode = engineMode == 'Swing'
isScalpMode = engineMode == 'Scalp'

// ══════════════════════════════════════════════════════════════════════════════
//  HYPER-GROWTH PROTOCOL
// ══════════════════════════════════════════════════════════════════════════════

growthTargetX = input.float(50.0, 'Hyper-Growth Target (x Initial)', minval = 1.1, step = 0.5, group = 'Hyper-Growth Protocol')
useMomentum = input.bool(true, 'Exploit: Momentum Entry?', group = 'Hyper-Growth Protocol', tooltip = 'Allows entry on strong ADX trends without waiting for Pin Bars.')
momentumThresh = input.int(18, 'Momentum Threshold (ADX)', minval = 10, maxval = 40, group = 'Hyper-Growth Protocol', tooltip = 'Swing = 18, Scalp = 28')

// Calculate Hyper-Status
targetEquityAmt = strategy.initial_capital * growthTargetX
isHyperPhase = strategy.equity < targetEquityAmt
progressPct = strategy.equity / targetEquityAmt * 100

// ══════════════════════════════════════════════════════════════════════════════
//  DATE RANGE & TRADE DIRECTION
// ══════════════════════════════════════════════════════════════════════════════

startDate = input.time(timestamp('2025-01-01 08:00'), 'Start Date')
endDate = input.time(timestamp('2069-12-30 00:00'), 'End Date')
inDateRange = time >= startDate and time <= endDate

tradeDirection = input.string(title = 'Trade Direction', defval = 'Both', options = ['Both', 'Long Only', 'Short Only'], confirm = false, group = 'Filters')
allowLong = tradeDirection == 'Both' or tradeDirection == 'Long Only'
allowShort = tradeDirection == 'Both' or tradeDirection == 'Short Only'

// ══════════════════════════════════════════════════════════════════════════════
//  EQUITY TRACKING & ADAPTIVE LOGIC (HARDENED)
// ══════════════════════════════════════════════════════════════════════════════

var float[] equityCurve = array.new_float(0)
var int lastClosedTrades = 0
var int lastEntryBar = -1
var int entryBarIndex = na

// Update equity curve on closed trade (with bounds check)
if strategy.closedtrades > lastClosedTrades
    closedEquity = strategy.equity - strategy.openprofit
    if not na(closedEquity) and closedEquity > 0
        array.push(equityCurve, closedEquity)
        // Prevent unbounded array growth
        if array.size(equityCurve) > MAX_EQUITY_HISTORY
            array.shift(equityCurve)
    lastClosedTrades := strategy.closedtrades

// Safe equity calculations with guards
currentClosedEquity = strategy.equity - strategy.openprofit
eqLength = input.int(21, 'Equity SMA Length', minval = 5, maxval = 100, group = 'Risk Management')
warmupTrades = input.int(3, 'Warm-up Closed Trades', minval = 0, maxval = 20, group = 'Risk Management')

inWarmup = strategy.closedtrades < warmupTrades
hasMinSamples = array.size(equityCurve) >= EQUITY_CURVE_MIN_SAMPLES

// Guarded average calculation
avgEquity = hasMinSamples and array.size(equityCurve) > 0 ? array.avg(equityCurve) : currentClosedEquity
avgEquity := avgEquity > FLOAT_EPSILON ? avgEquity : currentClosedEquity

// Equity Guard (Optional)
useEquityGuard = input.bool(false, 'Use Equity Guard?', group = 'Risk Management')
eqPercent = input.float(0.7, 'Position % in Cold Market', minval = 0.1, maxval = 1.0, group = 'Risk Management')

isStrategyCold = hasMinSamples and not inWarmup and currentClosedEquity < avgEquity

// OVERRIDE: Hyper Phase ignores cold state
if isHyperPhase
    isStrategyCold := false

// ══════════════════════════════════════════════════════════════════════════════
//  ATR MULTIPLIER (FIXED - CONST DEFAULT)
// ══════════════════════════════════════════════════════════════════════════════

// FIX: Must use const literal for input.float defval, not variable
atr_mult = input.float(1.8, title = 'Stop Loss Base (x*ATR)', minval = MIN_ATR_MULT, maxval = MAX_ATR_MULT, step = 0.1, group = 'Risk Management', tooltip = 'Swing default = 1.8, Scalp default = 1.3')
atr_mult_guard = input.float(0.9, 'Stop Loss Guard (x*ATR)', minval = 0.5, maxval = 2.0, group = 'Risk Management')

// Mode-aware override for atr_mult_use
atr_mult_base = isSwingMode ? 1.8 : 1.3
atr_mult_use = inWarmup ? atr_mult : isStrategyCold ? atr_mult_guard : atr_mult_base

// ══════════════════════════════════════════════════════════════════════════════
//  ADAPTIVE EQUITY COMPOUNDING CORE (HARDENED)
// ══════════════════════════════════════════════════════════════════════════════

erLen = 14
float change = 0.0
float volatility = VOLATILITY_FLOOR

if hasMinSamples and array.size(equityCurve) > erLen + 1
    prevEquity = array.get(equityCurve, array.size(equityCurve) - erLen - 1)
    if not na(prevEquity) and prevEquity > 0
        change := math.abs(currentClosedEquity - prevEquity)
    
    volSum = 0.0
    validCount = 0
    for i = 1 to erLen by 1
        if array.size(equityCurve) > i + 1
            e1 = array.get(equityCurve, array.size(equityCurve) - i)
            e2 = array.get(equityCurve, array.size(equityCurve) - i - 1)
            if not na(e1) and not na(e2)
                volSum := volSum + math.abs(e1 - e2)
                validCount := validCount + 1
    volatility := validCount > 0 and volSum > FLOAT_EPSILON ? volSum : VOLATILITY_FLOOR
else
    change := 0.0
    volatility := VOLATILITY_FLOOR

effRatio = volatility > FLOAT_EPSILON ? change / volatility : 0.0
effRatio := math.max(0, math.min(1, effRatio))

// 1️⃣ Adaptive SMA (Dynamic Memory Length)
lenAdaptive = 8 + (30 - 8) * (1 - effRatio)
lenAdaptive := math.max(MIN_ADAPTIVE_LEN, math.min(MAX_ADAPTIVE_LEN, lenAdaptive))
eqSMA = ta.sma(currentClosedEquity, math.round(lenAdaptive))

// 2️⃣ Logistic Multiplier (Confidence Curve)
epsilon = 0.02
distRaw = eqSMA > FLOAT_EPSILON ? (currentClosedEquity - eqSMA) / eqSMA : 0.0
dist = math.abs(distRaw) > epsilon ? distRaw : 0.0
confidence = 1 / (1 + math.exp(-4 * dist))
baseMult = 1.0 + 0.8 * confidence
baseMult := math.max(0.9, math.min(1.8, baseMult))

// 3️⃣ Acceleration Filter (Smart Smoothing)
vel = eqSMA - nz(eqSMA[1])
acc = vel - nz(vel[1])
accSmooth = ta.ema(acc, 5)
accImpact = math.max(0, math.min(1, (-accSmooth - 0.4) / 0.6))
accAdj = 1.0 - 0.1 * accImpact

// 4️⃣ Std-Dev Channel (Equity Envelope)
z = 2.2
eqStdev = ta.stdev(currentClosedEquity, math.round(lenAdaptive))
eqUpper = eqSMA + z * eqStdev
eqLower = eqSMA - z * eqStdev

chanAdj = currentClosedEquity < eqLower ? 0.95 : currentClosedEquity > eqUpper ? 1.03 : 1.0

// 5️⃣ Final Adaptive Multiplier (Mode-Aware)
lenFactor = isHyperPhase ? 0.8 : 1.0
lenAdaptive := math.max(MIN_ADAPTIVE_LEN, math.min(MAX_ADAPTIVE_LEN, lenAdaptive * lenFactor))

baseMultRange = isHyperPhase ? 1.0 : 0.9
maxMultRange = isHyperPhase ? 2.0 : 1.8
baseMult := math.max(baseMultRange, math.min(maxMultRange, baseMult))

chanAdj := currentClosedEquity < eqLower ? isHyperPhase ? 0.97 : 0.95 : currentClosedEquity > eqUpper ? isHyperPhase ? 1.05 : 1.03 : 1.0
accAdj := isHyperPhase ? 1.0 - 0.07 * accImpact : 1.0 - 0.1 * accImpact

multAdaptive = baseMult * accAdj * chanAdj
multAdaptive := math.max(MIN_ATR_MULT, math.min(MAX_ATR_MULT, multAdaptive))

// Apply globally
atr_mult_use := multAdaptive

// ══════════════════════════════════════════════════════════════════════════════
//  RISK MANAGEMENT - 97% FULL SEND
// ══════════════════════════════════════════════════════════════════════════════

// FIX (compile): input `defval` must be a `const` literal - it cannot be
// derived from another input's value (isSwingMode comes from the engineMode
// input, so a ternary on it is "input"-qualified, one step too dynamic for
// defval). Each checkbox below gets a fixed literal default.
//
// MULTI-TOGGLE: each named profile is its own on/off checkbox rather than a
// single-select dropdown. Only checkboxes belonging to the currently active
// Engine Mode are eligible - a Scalp profile enabled while running Swing
// mode is ignored, since its tick values don't fit Swing's holding style.
// If more than one is enabled within the active mode, priority order picks
// the winner deterministically (Sniper > Trend > Conservative for Swing;
// Default > Aggressive > Conservative for Scalp). If none are enabled for
// the active mode, falls back to Manual ticks. Resolved once into a
// var-tracked string on barstate.isfirst rather than every bar.
enableSwingSniper       = input.bool(true,  'Enable: Swing Sniper (36/12)',       group = 'Risk Management - Swing Profiles')
enableSwingTrend        = input.bool(false, 'Enable: Swing Trend (36/18)',        group = 'Risk Management - Swing Profiles')
enableSwingConservative = input.bool(false, 'Enable: Swing Conservative (48/18)', group = 'Risk Management - Swing Profiles')

enableScalpDefault      = input.bool(true,  'Enable: Scalp Default (10/4)',      group = 'Risk Management - Scalp Profiles')
enableScalpAggressive   = input.bool(false, 'Enable: Scalp Aggressive (8/3)',    group = 'Risk Management - Scalp Profiles')
enableScalpConservative = input.bool(false, 'Enable: Scalp Conservative (12/5)', group = 'Risk Management - Scalp Profiles')

manActivation = input.int(36, 'Manual Activation (Ticks) - fallback if no profile enabled for the active mode', minval = 1, maxval = 100, group = 'Risk Management')
manOffset = input.int(12, 'Manual Offset (Ticks) - fallback if no profile enabled for the active mode', minval = 1, maxval = 50, group = 'Risk Management')

var string effectiveRiskProfile = na
if barstate.isfirst
    effectiveRiskProfile := isSwingMode ?
      (enableSwingSniper ? 'Swing Sniper (36/12)' : enableSwingTrend ? 'Swing Trend (36/18)' : enableSwingConservative ? 'Swing Conservative (48/18)' : 'Manual') :
      (enableScalpDefault ? 'Scalp Default (10/4)' : enableScalpAggressive ? 'Scalp Aggressive (8/3)' : enableScalpConservative ? 'Scalp Conservative (12/5)' : 'Manual')

// 97% RISK PER TRADE
riskPerTradePct = input.float(97.0, 'Risk % Per Trade (FULL SEND)', minval = 50.0, maxval = 100.0, step = 1.0, group = 'Risk Management')

// Assign Ticks (Hardened with fallback) - unchanged, matches on effectiveRiskProfile
var int activeActivation = na
var int activeOffset = na

if effectiveRiskProfile == 'Swing Sniper (36/12)'
    activeActivation := 36
    activeOffset := 12
else if effectiveRiskProfile == 'Swing Trend (36/18)'
    activeActivation := 36
    activeOffset := 18
else if effectiveRiskProfile == 'Swing Conservative (48/18)'
    activeActivation := 48
    activeOffset := 18
else if effectiveRiskProfile == 'Scalp Default (10/4)'
    activeActivation := 10
    activeOffset := 4
else if effectiveRiskProfile == 'Scalp Aggressive (8/3)'
    activeActivation := 8
    activeOffset := 3
else if effectiveRiskProfile == 'Scalp Conservative (12/5)'
    activeActivation := 12
    activeOffset := 5
else
    activeActivation := manActivation
    activeOffset := manOffset

// Guard against invalid values
activeActivation := math.max(1, activeActivation)
activeOffset := math.max(1, activeOffset)

// Peak Equity Tracking (For Display Only)
var float equityPeak = 0.0
equityPeak := math.max(equityPeak, strategy.equity)
ddPercent = equityPeak > 0 ? (strategy.equity - equityPeak) / equityPeak * 100 : 0.0

// ══════════════════════════════════════════════════════════════════════════════
//  INDICATORS (MODE-AWARE)
// ══════════════════════════════════════════════════════════════════════════════

// FIX (compile): as above, defval can't depend on isSwingMode. Fixed
// literal defaults (Swing values) on the inputs; mode-aware "_use"
// variables mirror the atr_mult_use pattern so the EMA lengths still
// auto-switch with Engine Mode at runtime, same as before.
ema_fast = input.int(6, 'Fast EMA', minval = 2, maxval = 20, group = 'Indicators')
ema_medm = input.int(18, 'Medium EMA', minval = 5, maxval = 50, group = 'Indicators')
ema_slow = input.int(50, 'Slow EMA', minval = 20, maxval = 100, group = 'Indicators')
atr_valu = input.int(14, 'ATR Period', minval = 5, maxval = 50, group = 'Indicators')

ema_fast_use = isSwingMode ? 6 : 4
ema_medm_use = isSwingMode ? 18 : 9
ema_slow_use = isSwingMode ? 50 : 25

slowSMA = ta.sma(close, ema_slow_use)
medmEMA = ta.ema(close, ema_medm_use)
fastEMA = ta.ema(close, ema_fast_use)
atr = ta.atr(atr_valu)

// Guard against NA indicators
fastEMA := nz(fastEMA, close)
medmEMA := nz(medmEMA, close)
slowSMA := nz(slowSMA, close)
atr := nz(atr, close * 0.01)
atr := atr > FLOAT_EPSILON ? atr : close * 0.01

// EMA Fan Trend Detection
fanUpTrend = fastEMA > medmEMA and medmEMA > slowSMA
fanDnTrend = fastEMA < medmEMA and medmEMA < slowSMA

// Momentum Logic (Mode-aware threshold)
adxDefault = isSwingMode ? 18 : 28
momentumThreshFinal = momentumThresh > 0 ? momentumThresh : adxDefault
[diplus, diminus, adxValue] = ta.dmi(14, 14)
isStrongTrend = adxValue > momentumThreshFinal

// Pin Bar Detection (Hardened)
barRange = high - low
body = math.abs(close - open)
upperWick = high - math.max(close, open)
lowerWick = math.min(close, open) - low

// Mode-aware pin bar strictness
pinBarWickRatio = isSwingMode ? 0.66 : 0.70
pinBarBodyRatio = isSwingMode ? 0.34 : 0.30

bullishPinBar = barRange > FLOAT_EPSILON ? lowerWick >= pinBarWickRatio * barRange and body <= pinBarBodyRatio * barRange : false
bearishPinBar = barRange > FLOAT_EPSILON ? upperWick >= pinBarWickRatio * barRange and body <= pinBarBodyRatio * barRange : false

// Valid Triggers
validTriggerBull = isHyperPhase and useMomentum ? bullishPinBar or (isStrongTrend and close > high[1]) : bullishPinBar
validTriggerBear = isHyperPhase and useMomentum ? bearishPinBar or (isStrongTrend and close < low[1]) : bearishPinBar

// Price Pierce Detection
bullPierce = (low < fastEMA and close > fastEMA) or (low < medmEMA and close > medmEMA) or (low < slowSMA and close > slowSMA)
bearPierce = (high > fastEMA and close < fastEMA) or (high > medmEMA and close < medmEMA) or (high > slowSMA and close < slowSMA)

// ══════════════════════════════════════════════════════════════════════════════
//  VOLUME CONFIRMATION (SCALP REQUIRED)
// ══════════════════════════════════════════════════════════════════════════════

// FIX (compile): defval can't depend on isScalpMode. useVolumeConfirm,
// useFixedTP, useTimeExit are genuine on/off toggles the user clicks - a
// fixed literal default (false) is the honest fix; forcing them via a
// mode-driven "_use" override would make the checkbox lie about its own
// state. Toggle them on by hand when running Scalp, as intended.
// volumeMultiplier is a numeric threshold like the EMA lengths above, so it
// gets the same "_use" runtime-override treatment to keep auto-switching.
useVolumeConfirm = input.bool(false, 'Require Volume Confirmation?', group = 'Filters', tooltip = 'Scalp mode strongly recommends volume filter')
volumeLookback = input.int(20, 'Volume SMA Length', minval = 5, maxval = 100, group = 'Filters')
volumeMultiplier = input.float(1.0, 'Volume Multiplier Threshold', minval = 1.0, step = 0.1, group = 'Filters')
volumeMultiplier_use = isScalpMode ? 1.3 : 1.0

volumeAvg = ta.sma(volume, volumeLookback)
volumeConfirmed = volume >= volumeAvg * volumeMultiplier_use

// ══════════════════════════════════════════════════════════════════════════════
//  SCALP-SPECIFIC FEATURES (Only active in Scalp mode)
// ══════════════════════════════════════════════════════════════════════════════

useFixedTP = input.bool(false, 'Use Fixed Take-Profit?', group = 'Scalp Features', tooltip = 'Lock in gains fast for scalp mode')
tpMultiplier = input.float(1.5, 'TP = Entry + (ATR x Multiplier)', minval = 1.0, maxval = 5.0, step = 0.1, group = 'Scalp Features')

useTimeExit = input.bool(false, 'Use Time-Based Exit?', group = 'Scalp Features', tooltip = 'Exit if trade doesnt move within N bars')
maxBarsInTrade = input.int(20, 'Max Bars In Trade', minval = 5, maxval = 100, group = 'Scalp Features')

// ══════════════════════════════════════════════════════════════════════════════
//  FINAL ENTRY SIGNALS (HARDENED)
// ══════════════════════════════════════════════════════════════════════════════

// Duplicate prevention
longEntry  = fanUpTrend and bullPierce and validTriggerBull and (bar_index > lastEntryBar)
shortEntry = fanDnTrend and bearPierce and validTriggerBear and (bar_index > lastEntryBar)

// Volume confirmation
if useVolumeConfirm
    longEntry := longEntry and volumeConfirmed
    shortEntry := shortEntry and volumeConfirmed

// NOTE: no explicit NA guard needed here. Both nz() and na() fail to
// resolve cleanly against a series bool in this compiler (they keep
// collapsing to a numeric overload). It's moot anyway - Pine already
// treats an na bool as falsy inside `if` conditions automatically, so
// `if longEntry and ...` behaves identically whether longEntry is na or
// explicitly false. The guard was redundant defensive code, not a
// behavior change to remove.

// ══════════════════════════════════════════════════════════════════════════════
//  POSITION SIZING - 97% FULL EQUITY COMPOUNDING (HARDENED)
// ══════════════════════════════════════════════════════════════════════════════

calcSize(dir) =>
    stopDist = atr[1] * atr_mult_use
    stopPrice = dir == 1 ? low[1] - stopDist : high[1] + stopDist
    riskPerShare = math.abs(close - stopPrice)
    riskPerShare := math.max(riskPerShare, syminfo.mintick * 10)
    riskPerShare := riskPerShare > FLOAT_EPSILON ? riskPerShare : syminfo.mintick * 10
    
    // FULL EQUITY - NO CAPS
    availableEquity = strategy.equity - strategy.openprofit
    availableEquity := availableEquity > FLOAT_EPSILON ? availableEquity : strategy.initial_capital
    
    // 97% RISK ALLOCATION
    riskAmount = availableEquity * (riskPerTradePct / 100)
    qtyRisk = riskAmount / riskPerShare
    
    // HYPER EFFICIENCY - 97% capital usage, 3% slippage buffer
    efficiency = 0.97
    bufferMult = 0.0
    
    qtyMax = math.floor(availableEquity * efficiency / (close + atr[1] * bufferMult))
    qtyMax := qtyMax > 0 ? qtyMax : 1
    
    finalQty = math.min(qtyRisk, qtyMax)
    finalQty := finalQty > 0 ? finalQty : 0

// FIX (CW10003): calcSize() was only invoked inside the conditional entry
// blocks below, so on bars where the entry condition is false it never runs
// at all - inconsistent evaluation for a function that reads [1]-offset
// series. Call it unconditionally every bar here; the if-blocks below just
// reference the precomputed result.
qtyLongCalc = calcSize(1)
qtyShortCalc = calcSize(-1)

// ══════════════════════════════════════════════════════════════════════════════
//  EXECUTION (HARDENED)
// ══════════════════════════════════════════════════════════════════════════════

if longEntry and inDateRange and allowLong and strategy.position_size == 0
    qty = qtyLongCalc
    if qty > 0 and not na(qty)
        stopLoss = low[1] - atr[1] * atr_mult_use
        takeProfit = useFixedTP ? close + (atr[1] * tpMultiplier) : na
        comment = isHyperPhase ? (isSwingMode ? '🚀 SWING 97%' : '🚀 SCALP 97%') : (isSwingMode ? 'Swing 97%' : 'Scalp 97%')
        strategy.entry('long', strategy.long, qty = qty, comment = comment)
        if useFixedTP and not na(takeProfit)
            strategy.exit('exit long', from_entry = 'long', stop = stopLoss, limit = takeProfit, trail_points = activeActivation, trail_offset = activeOffset)
        else
            strategy.exit('exit long', from_entry = 'long', stop = stopLoss, trail_points = activeActivation, trail_offset = activeOffset)
        lastEntryBar := bar_index
        entryBarIndex := bar_index

if shortEntry and inDateRange and allowShort and strategy.position_size == 0
    qty = qtyShortCalc
    if qty > 0 and not na(qty)
        stopLoss = high[1] + atr[1] * atr_mult_use
        takeProfit = useFixedTP ? close - (atr[1] * tpMultiplier) : na
        comment = isHyperPhase ? (isSwingMode ? '🚀 SWING 97%' : '🚀 SCALP 97%') : (isSwingMode ? 'Swing 97%' : 'Scalp 97%')
        strategy.entry('short', strategy.short, qty = qty, comment = comment)
        if useFixedTP and not na(takeProfit)
            strategy.exit('exit short', from_entry = 'short', stop = stopLoss, limit = takeProfit, trail_points = activeActivation, trail_offset = activeOffset)
        else
            strategy.exit('exit short', from_entry = 'short', stop = stopLoss, trail_points = activeActivation, trail_offset = activeOffset)
        lastEntryBar := bar_index
        entryBarIndex := bar_index

// Trend Reversal Close
if ta.crossunder(fastEMA, medmEMA) and strategy.position_size > 0
    strategy.close_all(comment = 'Trend Change')
if ta.crossover(fastEMA, medmEMA) and strategy.position_size < 0
    strategy.close_all(comment = 'Trend Change')

// Time-Based Exit (Scalp Only)
if useTimeExit and strategy.position_size != 0 and not na(entryBarIndex)
    barsInTrade = bar_index - entryBarIndex
    if barsInTrade >= maxBarsInTrade
        strategy.close_all(comment = '⏱️ Time Exit')
        entryBarIndex := na

// ══════════════════════════════════════════════════════════════════════════════
//  ALERT CONDITIONS
// ══════════════════════════════════════════════════════════════════════════════

alertcondition(longEntry, title = '🟢 Long Entry Signal', message = 'Eve Engine v1.3 Unified - Long Entry Detected')
alertcondition(shortEntry, title = '🔴 Short Entry Signal', message = 'Eve Engine v1.3 Unified - Short Entry Detected')
alertcondition(isHyperPhase, title = '🚀 Hyper Phase Active', message = 'Eve Engine v1.3 Unified - Hyper Growth Mode Engaged')
alertcondition(progressPct >= 100, title = '🎯 Growth Target Hit', message = 'Eve Engine v1.3 Unified - Target Achieved')
alertcondition(engineMode == 'Swing', title = '📊 Swing Mode Active', message = 'Eve Engine v1.3 - Swing Mode')
alertcondition(engineMode == 'Scalp', title = '⚡ Scalp Mode Active', message = 'Eve Engine v1.3 - Scalp Mode')

// ══════════════════════════════════════════════════════════════════════════════
//  VISUALIZATION
// ══════════════════════════════════════════════════════════════════════════════

// Adaptive Multiplier (Visual Only)
multScaled = (multAdaptive - 1.0) * close * 0.05 + close
plot(multScaled, title = 'ATR Multiplier (visual)', color = color.new(color.orange, 0), style = plot.style_line, linewidth = 1)

// Background Highlights
bgcolor(isStrategyCold and useEquityGuard ? color.new(#768afc, 80) : na, title = 'Equity Guard Active (Cold)')
bgcolor(isHyperPhase ? color.new(color.purple, 90) : na, title = 'Hyper Phase')

// Plot Moving Averages
plot(fastEMA, color = color.new(color.red, 0), title = 'Fast EMA', linewidth = 1)
plot(medmEMA, color = color.new(color.blue, 0), title = 'Medium EMA', linewidth = 1)
plot(slowSMA, color = color.new(color.green, 0), title = 'Slow SMA', linewidth = 1)

// Pin Bar Markers
plotshape(bullishPinBar, style = shape.triangleup, location = location.belowbar, color = color.new(color.green, 0), size = size.tiny, title = 'Bullish Pin Bar')
plotshape(bearishPinBar, style = shape.triangledown, location = location.abovebar, color = color.new(color.red, 0), size = size.tiny, title = 'Bearish Pin Bar')

// Mode Label (Always Visible)
var label modeLabel = na
if barstate.islast
    if na(modeLabel)
        modeLabel := label.new(bar_index, high, '', style = label.style_label_left, color = isSwingMode ? color.blue : color.orange, textcolor = color.white)
    label.set_xy(modeLabel, bar_index, high)
    label.set_text(modeLabel, isSwingMode ? '📊 SWING MODE' : '⚡ SCALP MODE')
    label.set_color(modeLabel, isSwingMode ? color.blue : color.orange)

// ══════════════════════════════════════════════════════════════════════════════
//  PERFORMANCE TABLE (HARDENED)
// ══════════════════════════════════════════════════════════════════════════════

if barstate.islast
    winRate = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0
    profitFactor = strategy.grossloss != 0 ? strategy.grossprofit / math.abs(strategy.grossloss) : 0
    netProfit = strategy.netprofit
    totalTrades = strategy.closedtrades
    
    d_str = (dayofmonth(time) < 10 ? '0' : '') + str.tostring(dayofmonth(time))
    m_str = (month(time) < 10 ? '0' : '') + str.tostring(month(time))
    dateStr = d_str + '/' + m_str + '/' + str.tostring(year(time))
    
    c_gold = color.rgb(212, 175, 55)
    c_black = color.rgb(10, 10, 10)
    c_gray = color.rgb(30, 30, 30)
    c_text = color.rgb(220, 220, 220)
    c_green = color.rgb(0, 230, 118)
    c_red = color.rgb(255, 82, 82)
    c_purple = color.rgb(189, 63, 255)
    c_cyan = color.rgb(0, 255, 255)
    c_blue = color.rgb(0, 150, 255)
    
    pnlColor = netProfit >= 0 ? c_green : c_red
    
    // Main Performance Table (Bottom Left)
    var table perfTable = table.new(position.bottom_left, 2, 9, border_width = 1, border_color = c_gold, frame_color = c_gold, frame_width = 1)
    
    table.cell(perfTable, 0, 0, '✦ EVE ENGINE ✦', text_color = c_black, bgcolor = c_gold, text_size = size.normal, text_halign = text.align_center)
    table.cell(perfTable, 1, 0, 'v1.3 UNIFIED', text_color = c_black, bgcolor = c_gold, text_size = size.normal, text_halign = text.align_center)
    
    table.cell(perfTable, 0, 1, 'Equity USDT', text_color = c_text, bgcolor = c_black, text_size = size.small, text_halign = text.align_left)
    table.cell(perfTable, 1, 1, str.tostring(strategy.equity, '#.##'), text_color = c_text, bgcolor = c_black, text_size = size.small, text_halign = text.align_right)
    
    table.cell(perfTable, 0, 2, 'PnL Total', text_color = c_text, bgcolor = c_black, text_size = size.small, text_halign = text.align_left)
    table.cell(perfTable, 1, 2, str.tostring(netProfit, '#.##'), text_color = pnlColor, bgcolor = c_black, text_size = size.small, text_halign = text.align_right)
    
    table.cell(perfTable, 0, 3, 'Win Rate %', text_color = c_text, bgcolor = c_gray, text_size = size.small, text_halign = text.align_left)
    table.cell(perfTable, 1, 3, str.tostring(winRate, '#.#') + '%', text_color = c_gold, bgcolor = c_gray, text_size = size.small, text_halign = text.align_right)
    
    table.cell(perfTable, 0, 4, 'Profit Factor', text_color = c_text, bgcolor = c_black, text_size = size.small, text_halign = text.align_left)
    table.cell(perfTable, 1, 4, str.tostring(profitFactor, '#.##'), text_color = c_text, bgcolor = c_black, text_size = size.small, text_halign = text.align_right)
    
    table.cell(perfTable, 0, 5, 'Total Trades', text_color = c_text, bgcolor = c_gray, text_size = size.small, text_halign = text.align_left)
    table.cell(perfTable, 1, 5, str.tostring(totalTrades), text_color = c_text, bgcolor = c_gray, text_size = size.small, text_halign = text.align_right)
    
    table.cell(perfTable, 0, 6, 'Risk Per Trade', text_color = c_text, bgcolor = c_black, text_size = size.small, text_halign = text.align_left)
    table.cell(perfTable, 1, 6, str.tostring(riskPerTradePct, '#.#') + '%', text_color = c_purple, bgcolor = c_black, text_size = size.small, text_halign = text.align_right)
    
    table.cell(perfTable, 0, 7, 'Active Mode', text_color = c_text, bgcolor = c_black, text_size = size.small, text_halign = text.align_left)
    table.cell(perfTable, 1, 7, isSwingMode ? '📊 SWING' : '⚡ SCALP', text_color = isSwingMode ? c_blue : c_cyan, bgcolor = c_black, text_size = size.small, text_halign = text.align_right)
    
    table.cell(perfTable, 0, 8, 'Date', text_color = c_gold, bgcolor = c_black, text_size = size.tiny, text_halign = text.align_left)
    table.cell(perfTable, 1, 8, dateStr, text_color = c_gold, bgcolor = c_black, text_size = size.tiny, text_halign = text.align_right)
    
    // Mode & Growth Table (Bottom Right)
    startTime = startDate
    elapsedMs = time - startTime
    float elapsedYears = elapsedMs / (1000 * 60 * 60 * 24 * 365)
    elapsedYears := math.max(elapsedYears, FLOAT_EPSILON)
    
    finalEquity = strategy.equity
    initEquity = strategy.initial_capital
    geoGrowth = (math.pow(finalEquity / initEquity, 1 / elapsedYears) - 1) * 100
    
    var table modeTable = table.new(position.bottom_right, 2, 6, bgcolor = color.black, frame_width = 1)
    
    table.cell(modeTable, 0, 0, 'Modus', text_color = color.white, text_size = size.small)
    table.cell(modeTable, 1, 0, isHyperPhase ? '🚀 HYPER' : '🛡️ CONSERVATIVE', text_color = isHyperPhase ? c_purple : color.gray, text_size = size.tiny)
    
    table.cell(modeTable, 0, 1, 'Position Size', text_color = color.white, text_size = size.tiny)
    table.cell(modeTable, 1, 1, '97% FULL SEND', text_color = c_purple, text_size = size.tiny)
    
    table.cell(modeTable, 0, 2, 'Fixed TP', text_color = color.white, text_size = size.tiny)
    table.cell(modeTable, 1, 2, useFixedTP ? '✅ ' + str.tostring(tpMultiplier, '#.#') + 'x ATR' : '❌ OFF', text_color = useFixedTP ? c_cyan : color.gray, text_size = size.tiny)
    
    table.cell(modeTable, 0, 3, 'Time Exit', text_color = color.white, text_size = size.tiny)
    table.cell(modeTable, 1, 3, useTimeExit ? '✅ ' + str.tostring(maxBarsInTrade) + ' bars' : '❌ OFF', text_color = useTimeExit ? c_cyan : color.gray, text_size = size.tiny)
    
    table.cell(modeTable, 0, 4, 'Geo Growth', text_color = color.white, text_size = size.small)
    table.cell(modeTable, 1, 4, str.tostring(geoGrowth, '#.##') + '%', text_color = color.new(color.teal, 0), text_size = size.small)
    
    table.cell(modeTable, 0, 5, 'Progress to Target', text_color = color.white, text_size = size.tiny)
    table.cell(modeTable, 1, 5, str.tostring(progressPct, '#.#') + '%', text_color = progressPct >= 100 ? c_green : c_gold, text_size = size.tiny)
